{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "rewrites": [
    { "source": "/((?!api/onlyoffice-callback).*)", "destination": "/api/server" }
  ],
  "functions": {
    "api/server.js": { "maxDuration": 300 },
    "api/onlyoffice-callback.js": { "maxDuration": 60 }
  }
}
